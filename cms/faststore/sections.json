  {
    "name": "SizeGuide",
    "schema": {
      "title": "Size Guide",
      "description": "A 'Size Guide' link on the PDP that opens a modal with a size chart table",
      "type": "object",
      "properties": {
        "buttonLabel": {
          "title": "Button label",
          "type": "string",
          "default": "Size Guide"
        },
        "title": {
          "title": "Modal title",
          "type": "string",
          "default": "Find Your Size"
        },
        "note": {
          "title": "Footer note",
          "type": "string",
          "default": "All measurements are in centimetres (cm). If you are between sizes, we recommend sizing up."
        },
        "rows": {
          "title": "Size rows",
          "description": "One row per size. Leave empty to use the default XS–XXL mock data.",
          "type": "array",
          "items": {
            "title": "Size row",
            "type": "object",
            "properties": {
              "size":  { "title": "Size label (e.g. XS, S, M)", "type": "string" },
              "chest": { "title": "Chest (cm)",                  "type": "string" },
              "waist": { "title": "Waist (cm)",                  "type": "string" },
              "hips":  { "title": "Hips (cm)",                   "type": "string" }
            }
          }
        }
      }
    }
  },
  {
    "name": "CountdownBanner",
    "schema": {
      "title": "Countdown Banner",
      "description": "Full-width promotional banner with live countdown timer",
      "type": "object",
      "properties": {
        "message": {
          "title": "Message",
          "type": "string",
          "default": "Flash Sale — Limited time offer"
        },
        "endDate": {
          "title": "End date & time (ISO format)",
          "description": "e.g. 2026-06-01T23:59:00Z — banner disappears automatically when reached",
          "type": "string",
          "default": ""
        },
        "ctaLabel": {
          "title": "CTA button label",
          "type": "string",
          "default": "Shop Now"
        },
        "ctaUrl": {
          "title": "CTA button URL",
          "type": "string",
          "default": "/"
        },
        "ctaPosition": {
          "title": "CTA position",
          "type": "string",
          "enum": ["left", "center", "right"],
          "enumNames": ["Left", "Center", "Right"],
          "default": "right"
        },
        "backgroundColor": {
          "title": "Background color",
          "description": "Any CSS color: #1a1a1a, red, rgb(0,0,0)…",
          "type": "string",
          "default": "#1a1a1a"
        },
        "textColor": {
          "title": "Text color",
          "description": "Any CSS color: #ffffff, white…",
          "type": "string",
          "default": "#ffffff"
        },
        "fontFamily": {
          "title": "Font",
          "description": "Body = main font · Display = editorial font · Monospace = technical font",
          "type": "string",
          "enum": ["body", "display", "mono"],
          "enumNames": ["Body font", "Display font", "Monospace"],
          "default": "body"
        }
      }
    }
  }
]
