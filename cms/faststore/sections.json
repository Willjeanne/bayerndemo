[
  {
    "name": "HeroBanner",
    "schema": {
      "title": "Hero Banner",
      "description": "Large full-width image with title, subtitle and CTA button overlay",
      "type": "object",
      "properties": {
        "image": {
          "title": "Image (desktop)",
          "type": "string",
          "default": ""
        },
        "imageAlt": {
          "title": "Image description (alt)",
          "type": "string",
          "default": ""
        },
        "imageMobile": {
          "title": "Mobile image (optional)",
          "description": "If empty, the desktop image is used on mobile",
          "type": "string",
          "default": ""
        },
        "title": {
          "title": "Title",
          "type": "string",
          "default": ""
        },
        "subtitle": {
          "title": "Subtitle (optional)",
          "type": "string",
          "default": ""
        },
        "linkUrl": {
          "title": "Link URL (optional)",
          "type": "string",
          "default": ""
        },
        "linkLabel": {
          "title": "CTA button text (optional)",
          "type": "string",
          "default": "Discover"
        },
        "textPosition": {
          "title": "Text position",
          "type": "string",
          "enumNames": [
            "Top left", "Top center", "Top right",
            "Center left", "Center", "Center right",
            "Bottom left", "Bottom center", "Bottom right"
          ],
          "enum": [
            "top-left", "top-center", "top-right",
            "center-left", "center-center", "center-right",
            "bottom-left", "bottom-center", "bottom-right"
          ],
          "default": "bottom-left"
        },
        "textColor": {
          "title": "Text color",
          "type": "string",
          "enumNames": ["White", "Black"],
          "enum": ["white", "black"],
          "default": "white"
        },
        "overlayOpacity": {
          "title": "Dark overlay opacity (0-100)",
          "type": "number",
          "default": 30,
          "minimum": 0,
          "maximum": 100
        }
      }
    }
  },
  {
    "name": "LookbookGrid",
    "schema": {
      "title": "Lookbook Grid",
      "description": "3 editorial cells side by side with image, title and link",
      "type": "object",
      "required": ["cell1", "cell2", "cell3"],
      "properties": {
        "textPosition": {
          "title": "Text position",
          "type": "string",
          "enumNames": [
            "Top left", "Top center", "Top right",
            "Center left", "Center", "Center right",
            "Bottom left", "Bottom center", "Bottom right"
          ],
          "enum": [
            "top-left", "top-center", "top-right",
            "center-left", "center-center", "center-right",
            "bottom-left", "bottom-center", "bottom-right"
          ],
          "default": "center-center"
        },
        "textColor": {
          "title": "Text color",
          "type": "string",
          "enumNames": ["White", "Black"],
          "enum": ["white", "black"],
          "default": "white"
        },
        "cell1": {
          "title": "Cell 1",
          "type": "object",
          "required": ["image", "imageAlt", "title", "linkUrl", "linkLabel"],
          "properties": {
            "image": {
              "title": "Image URL",
              "type": "string",
              "default": "https://images.unsplash.com/photo-1490481651871-ab68de25d43d?w=800&h=1067&fit=crop"
            },
            "imageAlt": {
              "title": "Image description (alt)",
