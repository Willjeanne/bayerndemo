              "default": "New Women's Collection"
            },
            "title": {
              "title": "Title",
              "type": "string",
              "default": "New Collection"
            },
            "subtitle": {
              "title": "Subtitle (optional)",
              "type": "string",
              "default": "Spring — Summer 2025"
            },
            "linkUrl": {
              "title": "Link URL",
              "type": "string",
              "default": "/outillage"
            },
            "linkLabel": {
              "title": "CTA button text",
              "type": "string",
              "default": "Discover"
            }
          }
        },
        "cell2": {
          "title": "Cell 2",
          "type": "object",
          "required": ["image", "imageAlt", "title", "linkUrl", "linkLabel"],
          "properties": {
            "image": {
              "title": "Image URL",
              "type": "string",
              "default": "https://images.unsplash.com/photo-1558769132-cb1aea458c5e?w=800&h=1067&fit=crop"
            },
            "imageAlt": {
              "title": "Image description (alt)",
              "type": "string",
              "default": "Winter Trends"
            },
            "title": {
              "title": "Title",
              "type": "string",
              "default": "Winter Trends"
            },
            "subtitle": {
              "title": "Subtitle (optional)",
              "type": "string",
              "default": "Editorial selection"
            },
            "linkUrl": {
              "title": "Link URL",
              "type": "string",
              "default": "/outillage"
            },
            "linkLabel": {
              "title": "CTA button text",
              "type": "string",
              "default": "Explore"
            }
          }
        },
        "cell3": {
          "title": "Cell 3",
          "type": "object",
          "required": ["image", "imageAlt", "title", "linkUrl", "linkLabel"],
          "properties": {
            "image": {
              "title": "Image URL",
              "type": "string",
              "default": "https://images.unsplash.com/photo-1469334031218-e382a71b716b?w=800&h=1067&fit=crop"
            },
            "imageAlt": {
              "title": "Image description (alt)",
              "type": "string",
              "default": "New Arrivals"
            },
            "title": {
              "title": "Title",
              "type": "string",
              "default": "New Arrivals"
            },
            "subtitle": {
              "title": "Subtitle (optional)",
              "type": "string"
            },
            "linkUrl": {
              "title": "Link URL",
              "type": "string",
              "default": "/outillage"
            },
            "linkLabel": {
              "title": "CTA button text",
              "type": "string",
              "default": "View all"
            }
          }
        }
      }
    }
  },
  {
    "name": "FullWidthShelf",
    "schema": {
      "title": "Full Width Shelf",
      "description": "Full-width product carousel with image swap on hover",
      "type": "object",
      "properties": {
        "title": {
          "title": "Section title (optional)",
          "type": "string",
          "default": ""
        },
        "categorySlug": {
          "title": "Category Slug",
          "description": "Exact category name as it appears in VTEX Admin (e.g. Clothes, Accessories, Bags, Pants & Skirts). Case-insensitive.",
          "type": "string",
          "default": ""
        },
        "count": {
          "title": "Number of products to display",
          "type": "number",
          "default": 8,
          "enum": [4, 8, 12],
          "enumNames": ["4 products", "8 products", "12 products"]
        }
      }
    }
  },
