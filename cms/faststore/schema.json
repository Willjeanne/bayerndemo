{
  "$base": "vtex.faststore@3",
  "components": {
    "CountdownBanner": {
      "$extends": [
        "#/$defs/base-component"
      ],
      "$componentKey": "CountdownBanner",
      "$componentTitle": "Countdown Banner",
      "title": "Countdown Banner",
      "description": "Full-width promotional bar with live countdown timer — disappears when expired",
      "type": "object",
      "required": [
        "message",
        "endDate"
      ],
      "properties": {
        "message": {
          "title": "Promotional message",
          "type": "string",
          "default": "Limited offer"
        },
        "endDate": {
          "title": "End date (ISO format: YYYY-MM-DDTHH:MM:SS)",
          "description": "Example: 2026-12-31T23:59:59",
          "type": "string",
          "default": "2026-12-31T23:59:59"
        },
        "ctaLabel": {
          "title": "CTA button text (optional)",
          "type": "string",
          "default": ""
        },
        "ctaUrl": {
          "title": "CTA button URL (optional)",
          "type": "string",
          "default": ""
        },
        "backgroundColor": {
          "title": "Background color",
          "type": "string",
          "default": "#DC052D"
        },
        "textColor": {
          "title": "Text color",
          "type": "string",
          "default": "#FFFFFF"
        }
      }
    },
    "FullWidthShelf": {
      "$extends": [
        "#/$defs/base-component"
      ],
      "$componentKey": "FullWidthShelf",
      "$componentTitle": "Full Width Shelf",
      "title": "Full Width Shelf",
      "description": "Full-width product carousel fetched from VTEX catalog by category ID",
      "type": "object",
      "required": [
        "categoryId"
      ],
      "properties": {
        "title": {
          "title": "Section title (optional)",
          "type": "string",
          "default": ""
        },
        "categoryId": {
          "title": "Category ID",
          "description": "Integer ID of the VTEX category (found in Admin > Catalog > Categories URL)",
          "type": "integer",
          "default": 1
        },
        "count": {
          "title": "Number of products to display",
          "type": "integer",
          "enumNames": [
            "4 products",
            "8 products",
            "12 products"
          ],
          "enum": [
            4,
            8,
            12
          ],
          "default": 8
        }
      }
    },
    "HeroBanner": {
      "$extends": [
        "#/$defs/base-component"
      ],
      "$componentKey": "HeroBanner",
      "$componentTitle": "Hero Banner",
      "title": "Hero Banner",
      "description": "Full-width image with title, subtitle and CTA button overlay",
      "type": "object",
      "required": [],
      "properties": {
        "image": {
          "title": "Desktop Image",
          "type": "string",
          "widget": {
            "ui:widget": "media-gallery",
            "restrictMediaTypes": {
              "video": true,
              "image": [
                "png",
                "jpg",
                "jpeg",
                "gif",
                "svg",
                "webp"
              ]
            }
          }
        },
        "imageAlt": {
          "title": "Image description (alt text)",
          "type": "string",
          "default": ""
        },
        "imageMobile": {
          "title": "Mobile image (optional)",
          "description": "If empty, the desktop image is used on mobile",
          "type": "string",
          "widget": {
            "ui:widget": "media-gallery",
            "restrictMediaTypes": {
              "video": true,
              "image": [
                "png",
                "jpg",
                "jpeg",
                "gif",
                "svg",
                "webp"
              ]
            }
          }
        },
        "title": {
          "title": "Title",
          "type": "string",
          "default": ""
        },
        "subtitle": {
          "title": "Subtitle (optional)",
          "type": "string",
          "default": ""
        },
        "linkUrl": {
          "title": "Link URL (optional)",
          "type": "string",
          "default": ""
        },
        "linkLabel": {
          "title": "CTA button text (optional)",
          "type": "string",
          "default": "Shop now"
        },
        "textPosition": {
          "title": "Text position",
          "type": "string",
          "enumNames": [
            "Top left",
            "Top center",
            "Top right",
            "Middle left",
            "Center",
            "Middle right",
            "Bottom left",
            "Bottom center",
            "Bottom right"
          ],
          "enum": [
            "top-left",
            "top-center",
            "top-right",
            "middle-left",
            "center",
            "middle-right",
            "bottom-left",
            "bottom-center",
            "bottom-right"
          ],
          "default": "center"
        },
        "textColor": {
          "title": "Text color",
          "type": "string",
          "enumNames": [
            "White",
            "Black"
          ],
          "enum": [
            "white",
            "black"
          ],
          "default": "white"
        },
        "overlayOpacity": {
          "title": "Dark overlay opacity (0–100)",
          "description": "0 = no overlay, 100 = fully black",
          "type": "integer",
          "default": 30
        }
      }
    },
